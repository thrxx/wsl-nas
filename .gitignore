# =============================================================================
# Игнорируемые файлы для WSL-NAS проекта
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Виртуализация и WSL (Критично!)
# -----------------------------------------------------------------------------
# Согласно разделу "Хранение данных": диск ext4.vhdx хранится в AppData и 
# весит гигабайты. Его нельзя коммитить в Git.
*.vhdx
*.vhdx.lock
ext4.vhdx
Packages/
LocalState/

# -----------------------------------------------------------------------------
# 2. Безопасность и Секреты (Согласно разделу "Security")
# -----------------------------------------------------------------------------
# Базы данных Samba (содержат хеши паролей пользователей)
*.tdb
*.ldb
private/
smbpasswd
smbusers

# Файлы конфигурации бэкапов (содержат токены и ключи шифрования)
rclone.conf
restic-repo/
*.key
*.pem
*.env
backup.key

# -----------------------------------------------------------------------------
# 3. Логи и Временные файлы
# -----------------------------------------------------------------------------
# Логи Samba и скриптов бэкапа (/var/log/samba/, /var/log/nas-backup.log)
*.log
samba/
logs/

# Кэш и временные файлы ОС
Thumbs.db
desktop.ini
.DS_Store
$RECYCLE.BIN/
System Volume Information/
AppData/Local/Temp/

# -----------------------------------------------------------------------------
# 4. Редакторы кода и IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# 5. Специфичное для проекта
# -----------------------------------------------------------------------------
# Если вы случайно создадите папку бэкапов внутри репозитория
backups/
*.tar.gz
*.zip
*.bak

# Конфиги, которые могут отличаться от эталонных в папке /config
# config/local.smb.conf
# config/local.wsl.conf